#### 3. Personnaliser le système

Créez un script de personnalisation qui sera exécuté lors du build : 

```bash
# Éditer le script de customization
vim airootfs/root/customize_airootfs.sh
```

Contenu complet :

```bash
#!/usr/bin/env bash

set -e -u

echo "=== Customization de Ma Distro Arch ==="

# Configurer le locale
sed -i 's/#fr_FR.UTF-8/fr_FR.UTF-8/' /etc/locale.gen
sed -i 's/#en_US.UTF-8/en_US.UTF-8/' /etc/locale.gen
locale-gen

echo "LANG=fr_FR.UTF-8" > /etc/locale. conf

# Configurer le clavier
echo "KEYMAP=fr" > /etc/vconsole. conf

# Configurer le timezone
ln -sf /usr/share/zoneinfo/Europe/Paris /etc/localtime

# Configurer le hostname
echo "arch-distro" > /etc/hostname

# Configurer hosts
cat > /etc/hosts << EOF
127.0.0.1   localhost
:: 1         localhost
127.0.1.1   arch-distro.localdomain arch-distro
EOF

# Activer les services
systemctl enable NetworkManager
systemctl enable sddm
systemctl enable sshd

# Créer un utilisateur
useradd -m -G wheel,audio,video,optical,storage -s /bin/bash archuser
echo "archuser:archlinux" | chpasswd

# Configurer le mot de passe root
echo "root:archlinux" | chpasswd

# Permettre sudo pour le groupe wheel
sed -i 's/# %wheel ALL=(ALL: ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# Configuration de pacman (couleurs, parallel downloads)
sed -i 's/#Color/Color/' /etc/pacman.conf
sed -i 's/#ParallelDownloads = 5/ParallelDownloads = 10/' /etc/pacman.conf

# Activer multilib (pour les applications 32-bit)
cat >> /etc/pacman.conf << EOF

[multilib]
Include = /etc/pacman.d/mirrorlist
EOF

# Message de bienvenue
cat > /etc/issue << 'EOF'
 _____         _       ____  _     _            
|  _  |___ ___| |_    |    \|_|___| |_ ___ ___ 
|     |  _|  _|   |   |  |  | |_ -|  _|  _| .  |
|__|__|_| |___|_|_|   |____/|_|___|_| |_| |___|
                                                
EOF

# Message après login
cat > /etc/motd << 'EOF'
╔════════════════════════════════════════╗
║   Bienvenue sur Ma Distro Arch Linux   ║
║            Version 1.0                 ║
║                                        ║
║   User: archuser / Pass: archlinux     ║
║   Root password: archlinux             ║
╚════════════════════════════════════════╝
EOF

# Configuration de neofetch pour l'afficher au login
echo "neofetch" >> /home/archuser/.bashrc

# Créer un script d'installation
cat > /usr/local/bin/install-system << 'INSTALL'
#!/bin/bash
echo "Lancement de l'installation..."
archinstall
INSTALL

chmod +x /usr/local/bin/install-system

# Installer yay (AUR helper) pour l'utilisateur
sudo -u archuser bash << 'EOF'
cd /tmp
git clone https://aur.archlinux.org/yay.git
cd yay
makepkg -si --noconfirm
cd .. 
rm -rf yay
EOF

echo "=== Customization terminée ==="
```

Rendre le script exécutable :

```bash
chmod +x airootfs/root/customize_airootfs.sh
```

#### 4. Personnaliser la configuration de l'ISO

```bash
# Éditer profiledef.sh
vim profiledef.sh
```

Contenu : 

```bash
#!/usr/bin/env bash

iso_name="ma-distro-arch"
iso_label="MA_DISTRO_$(date +%Y%m)"
iso_publisher="Votre Nom <votre. email@example.com>"
iso_application="Ma Distribution Arch Linux Personnalisée"
iso_version="$(date +%Y. %m.%d)"
install_dir="arch"

# Boot modes supportés
bootmodes=('bios. syslinux. mbr' 'bios.syslinux.eltorito'
           'uefi-ia32.grub. esp' 'uefi-x64.grub.esp'
           'uefi-ia32.grub.eltorito' 'uefi-x64.grub.eltorito')

arch="x86_64"
pacman_conf="pacman.conf"

# Type d'image pour airootfs
airootfs_image_type="squashfs"

# Options de compression (xz pour meilleure compression, zstd pour rapidité)
airootfs_image_tool_options=('-comp' 'xz' '-Xbcj' 'x86' '-b' '1M' '-Xdict-size' '1M')

# Permissions des fichiers
file_permissions=(
  ["/etc/shadow"]="0:0:400"
  ["/root"]="0:0:750"
  ["/root/.automated_script. sh"]="0:0:755"
  ["/usr/local/bin/choose-mirror"]="0:0:755"
  ["/usr/local/bin/Installation_guide"]="0:0:755"
  ["/usr/local/bin/livecd-sound"]="0:0:755"
  ["/usr/local/bin/install-system"]="0:0:755"
)
```

