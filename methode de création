sudo mkarchiso -v -w work -o out archlive

# Lister les fichiers de l'ISO
isoinfo -l -i out/ma-distro-arch-*.iso

# Monter l'ISO pour inspection
sudo mkdir -p /mnt/iso
sudo mount -o loop out/ma-distro-arch-*.iso /mnt/iso
ls -R /mnt/iso
sudo umount /mnt/iso
```

