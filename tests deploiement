sudo apt install sysbench

# Test CPU
sysbench cpu --threads=4 --time=60 run

# Test mémoire
sysbench memory --threads=4 --memory-total-size=10G run

# Test I/O
sysbench fileio --file-test-mode=seqwr --file-total-size=2G prepare
sysbench fileio --file-test-mode=seqwr --file-total-size=2G run
sysbench fileio --file-test-mode=seqwr --file-total-size=2G cleanup
```

#### UnixBench

```bash
# Télécharger
