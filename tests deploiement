# Script de benchmark
#!/bin/bash
APPS=("firefox" "libreoffice" "gimp")
for app in "${APPS[@]}"; do
    echo "Test $app..."
    TIME=$( { time $app & } 2>&1 | grep real | awk '{print $2}')
