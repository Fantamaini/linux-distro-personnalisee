## Tests de régression

### Suite de tests automatisés

```bash
#!/bin/bash

LOGFILE="test-results-$(date +%Y%m%d-%H%M%S).log"

echo "=== Suite de tests - Ma Distribution ===" | tee $LOGFILE

# Test 1 : Système démarre
echo "Test 1: Vérification démarrage..." | tee -a $LOGFILE
if systemctl is-system-running &>/dev/null; then
    echo "✓ PASS" | tee -a $LOGFILE
else
    echo "✗ FAIL" | tee -a $LOGFILE
fi

# Test 2 :  Réseau fonctionne
echo "Test 2: Vérification réseau..." | tee -a $LOGFILE
if ping -c 1 8.8.8.8 &>/dev/null; then
    echo "✓ PASS" | tee -a $LOGFILE
else
    echo "✗ FAIL" | tee -a $LOGFILE
fi

# Test 3 : Services critiques actifs
echo "Test 3: Vérification services..." | tee -a $LOGFILE
SERVICES=("NetworkManager" "sshd")
for service in "${SERVICES[@]}"; do
    if systemctl is-active --quiet $service; then
        echo "  ✓ $service actif" | tee -a $LOGFILE
    else
        echo "  ✗ $service inactif" | tee -a $LOGFILE
    fi
done

# Test 4 :  Applications présentes
echo "Test 4: Vérification applications..." | tee -a $LOGFILE
APPS=("vim" "git" "firefox")
for app in "${APPS[@]}"; do
    if command -v $app &>/dev/null; then
        echo "  ✓ $app installé" | tee -a $LOGFILE
    else
        echo "  ✗ $app manquant" | tee -a $LOGFILE
    fi
done

# Test 5 :  Espace disque
echo "Test 5: Vérification espace disque..." | tee -a $LOGFILE
USAGE=$(df / | tail -1 | awk '{print $5}' | sed 's/%//')
if [ $USAGE -lt 80 ]; then
    echo "  ✓ Espace suffisant ($USAGE%)" | tee -a $LOGFILE
else
    echo "  ✗ Espace insuffisant ($USAGE%)" | tee -a $LOGFILE
fi

echo "=== Tests terminés ===" | tee -a $LOGFILE
echo "Rapport :  $LOGFILE"
```

